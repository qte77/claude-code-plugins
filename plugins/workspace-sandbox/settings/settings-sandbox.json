{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "enableWeakerNestedSandbox": false,
    "network": {
      "allowLocalBinding": true,
      "allowedHosts": ["api.github.com"]
    },
    "filesystem": {
      "write": {
        "allowOnly": [
          "/tmp/claude-1000",
          ".git"
        ]
      }
    }
  },
  "permissions": {
    "allow": [
      "Edit(src/**)",
      "Edit(docs/)",
      "Edit(tests/)"
    ]
  }
}
